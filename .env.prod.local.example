# ============================================================
# MeritCap Backend - Production Profile (Local Run)
# ============================================================
# Usage:
#   cp .env.prod.local.example .env.prod.local
#   source .env.prod.local
#   ./mvnw spring-boot:run -Dspring-boot.run.profiles=prod
#
# This runs with application-prod.yaml but against local-reachable infra
# (for example DB via SSH tunnel).
# ============================================================

# Force prod profile when this file is sourced
export SPRING_PROFILES_ACTIVE="prod"

# Database (point to tunnel/direct prod-like DB)
export DB_URL="jdbc:mysql://localhost:3306/meritcap?allowPublicKeyRetrieval=true&useSSL=false"
export DB_USERNAME="CHANGE_ME"
export DB_PASSWORD="CHANGE_ME"

# AWS Cognito
export COGNITO_USER_POOL_ID="CHANGE_ME"
export COGNITO_CLIENT_ID="CHANGE_ME"
export COGNITO_CLIENT_SECRET="CHANGE_ME"
export AWS_REGION="ap-south-2"

# IAM Credentials
export IAM_MERITCAP_ACCESS_KEY_ID="CHANGE_ME"
export IAM_MERITCAP_SECRET_ACCESS_KEY="CHANGE_ME"

# S3
export S3_BUCKET_NAME="CHANGE_ME"

# Mail
export MAIL_HOST="smtp.gmail.com"
export MAIL_PORT="587"
export MAIL_USERNAME="CHANGE_ME"
export MAIL_PASSWORD="CHANGE_ME"

# App
export FRONTEND_URL="https://meritcap.com"
export SEND_ACTUAL_EMAILS="false"
