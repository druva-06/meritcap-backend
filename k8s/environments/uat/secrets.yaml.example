# NEVER commit real values.
apiVersion: v1
kind: Secret
metadata:
  name: meritcap-backend-secrets
  namespace: uat
type: Opaque
stringData:
  DB_URL: "CHANGE_ME"
  DB_USERNAME: "CHANGE_ME"
  DB_PASSWORD: "CHANGE_ME"
  MAIL_HOST: "smtp.gmail.com"
  MAIL_PORT: "587"
  MAIL_USERNAME: "CHANGE_ME"
  MAIL_PASSWORD: "CHANGE_ME"
  COGNITO_USER_POOL_ID: "CHANGE_ME"
  COGNITO_CLIENT_ID: "CHANGE_ME"
  COGNITO_CLIENT_SECRET: "CHANGE_ME"
  AWS_REGION: "ap-south-2"
  IAM_MERITCAP_ACCESS_KEY_ID: "CHANGE_ME"
  IAM_MERITCAP_SECRET_ACCESS_KEY: "CHANGE_ME"
  S3_BUCKET_NAME: "CHANGE_ME"
  FRONTEND_URL: "https://uat.meritcap.com"
  SEND_ACTUAL_EMAILS: "true"
  SPRING_PROFILES_ACTIVE: "uat"
