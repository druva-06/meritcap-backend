# ============================================================
# MeritCap Backend - Environment Variables
# ============================================================
# Copy this file to .env and fill in the values:
#   cp .env.example .env
#
# Then source before running:
#   source .env && ./mvnw spring-boot:run
# ============================================================

# Database
export DB_URL="jdbc:mysql://localhost:3306/meritcap?allowPublicKeyRetrieval=true&useSSL=false"
export DB_USERNAME="CHANGE_ME"
export DB_PASSWORD="CHANGE_ME"

# AWS Cognito
export COGNITO_USER_POOL_ID="CHANGE_ME"
export COGNITO_CLIENT_ID="CHANGE_ME"
export COGNITO_CLIENT_SECRET="CHANGE_ME"
export AWS_REGION="ap-south-2"

# IAM Credentials
export IAM_MERITCAP_ACCESS_KEY_ID="CHANGE_ME"
export IAM_MERITCAP_SECRET_ACCESS_KEY="CHANGE_ME"

# S3
export S3_BUCKET_NAME="CHANGE_ME"

# ── Email ────────────────────────────────────────────────────────────────────
# SEND_ACTUAL_EMAILS=false  → signup link returned in API response (no SMTP)
# SEND_ACTUAL_EMAILS=true   → real email sent via Gmail SMTP
#
# To enable real email in the future:
#   1. Create a Gmail App Password:
#      myaccount.google.com → Security → 2-Step Verification → App passwords
#   2. Set SEND_ACTUAL_EMAILS=true below
#   3. Set MAIL_USERNAME to your Gmail address
#   4. Set MAIL_PASSWORD to the App Password (NOT your Gmail login password)
# ─────────────────────────────────────────────────────────────────────────────
export MAIL_HOST="smtp.gmail.com"
export MAIL_PORT="587"
export MAIL_USERNAME="disabled"
export MAIL_PASSWORD="disabled"
export SEND_ACTUAL_EMAILS="false"

# App
export FRONTEND_URL="http://localhost:3000"
